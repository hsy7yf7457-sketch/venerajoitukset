    "CFBundleName" : {
      "comment" : "Bundle name",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "FinnishMarineSpeedLimits"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allowing location “Always” lets the app alert you when you enter or leave a speed-limit or wake-restriction zone during a trip, even with the screen off."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun sallit sijainnin ”Aina”, sovellus voi ilmoittaa, kun saavut nopeus- tai aallokkorajoitusalueelle tai poistut siltä matkan aikana, myös näytön ollessa sammuksissa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du tillåter plats ”Alltid” kan appen avisera dig när du kommer in i eller lämnar en fart- eller svallbegränsningszon under en tur, även med skärmen avstängd."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your position is used to show the marine speed limit and restrictions where you are."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sijaintiasi käytetään näyttämään merenkulun nopeusrajoitus ja rajoitukset olinpaikassasi."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din position används för att visa sjöfartens fartbegränsning och begränsningar där du befinner dig."
          }
        }
      }
    }
  },
  "version" : "1.0"
}