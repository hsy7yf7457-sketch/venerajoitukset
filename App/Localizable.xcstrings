    "© Väylävirasto · CC BY 4.0" : {
      "comment" : "A copyright notice displayed at the bottom of the screen.",
      "isCommentAutoGenerated" : true
    },
    "Alerts you (even in the background) when you exceed the limit by more than the threshold. Starts 10 seconds after entering a speed-limit zone. Requires location set to “Always”." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alerts you (even in the background) when you exceed the limit by more than the threshold. Starts 10 seconds after entering a speed-limit zone. Requires location set to “Always”."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varoittaa (myös taustalla), kun ylität rajoituksen enemmän kuin varoitusrajan verran. Alkaa 10 sekuntia nopeusrajoitusalueelle saapumisen jälkeen. Edellyttää sijainniksi asetettua ”aina”."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varnar dig (även i bakgrunden) när du överskrider gränsen med mer än tröskeln. Startar 10 sekunder efter att du kommit in i en fartbegränsningszon. Kräver att platsåtkomst är inställd på ”Alltid”."
          }
        }
      }
    },
    "Alerts you (even in the background) when you go more than 10% over the limit. Starts 10 seconds after entering a speed-limit zone. Requires location set to “Always”." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alerts you (even in the background) when you go more than 10% over the limit. Starts 10 seconds after entering a speed-limit zone. Requires location set to “Always”."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varoittaa (myös taustalla), kun ylität rajoituksen yli 10 %:lla. Alkaa 10 sekuntia nopeusrajoitusalueelle saapumisen jälkeen. Edellyttää sijainniksi asetettua ”aina”."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varnar dig (även i bakgrunden) när du kör mer än 10 % över gränsen. Startar 10 sekunder efter att du kommit in i en fartbegränsningszon. Kräver att platsåtkomst är inställd på ”Alltid”."
          }
        }
      }
    },
    "Alerts you when you enter or leave a restricted area, so you don't have to keep watching the screen." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alerts you when you enter or leave a restricted area, so you don't have to keep watching the screen."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilmoittaa, kun saavut rajoitusalueelle tai poistut siltä, jotta sinun ei tarvitse tuijottaa näyttöä."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meddelar dig när du kommer in i eller lämnar ett begränsat område, så att du inte behöver hålla ögonen på skärmen."
          }
        }
      }
    },
    "Allow location “Always” for alerts with the screen off." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow location “Always” for alerts with the screen off."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salli sijainti ”Aina” saadaksesi ilmoitukset näytön ollessa sammuksissa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillåt plats ”Alltid” för aviseringar med skärmen avstängd."
          }
        }
      }
    },
