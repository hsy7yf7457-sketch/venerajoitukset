    "Background alerts need location access set to “Always”. Tap to open Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Background alerts need location access set to “Always”. Tap to open Settings."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taustailmoitukset vaativat, että sijainnin käyttö on asetettu ”aina”. Avaa asetukset napauttamalla."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bakgrundsvarningar kräver att platsåtkomst är inställd på ”Alltid”. Tryck för att öppna Inställningar."
          }
        }
      }
    },
    "Background alerts only work if you allow location access “Always”. Tap to open Settings." : {
      "localizations" : {
        "en" : {
