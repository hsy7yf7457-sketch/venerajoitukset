    "Full-scale value of the gauge. The number keeps counting above it, but the arc stays at the maximum." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Full-scale value of the gauge. The number keeps counting above it, but the arc stays at the maximum."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mittarin asteikon yläraja. Lukema jatkaa nousuaan sen yli, mutta kaari pysyy enimmäisarvossa."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mätarens maxvärde. Siffran fortsätter räkna över det, men bågen stannar på maxvärdet."
          }
        }
      }
    },
    "Get a local alert when you enter and when you leave a zone. Requires location set to “Always”." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get a local alert when you enter and when you leave a zone. Requires location set to “Always”."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saat ilmoituksen, kun saavut alueelle ja kun poistut siltä. Edellyttää sijaintiasetusta ”Aina”."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Få en avisering när du kommer in i och lämnar ett område. Kräver platsinställningen ”Alltid”."
          }
        }
      }
    },
    "Important: for alerts to work, allow location access “Always”. iOS grants “While Using” first — you may need to return to the home screen after granting access, then reopen the app to enable “Always”." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important: for alerts to work, allow location access “Always”. iOS grants “While Using” first — you may need to return to the home screen after granting access, then reopen the app to enable “Always”."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tärkeää: jotta ilmoitukset toimivat, salli sijainnin käyttö ”aina”. iOS myöntää ensin luvan ”sovellusta käytettäessä” — sinun on ehkä palattava kotinäyttöön luvan myöntämisen jälkeen ja avattava sovellus uudelleen ottaaksesi ”aina”-asetuksen käyttöön."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viktigt: för att varningarna ska fungera, tillåt platsåtkomst ”Alltid”. iOS ger först ”När appen används” — du kan behöva återgå till hemskärmen efter att du gett åtkomst och sedan öppna appen igen för att aktivera ”Alltid”."
          }
        }
      }
    },
